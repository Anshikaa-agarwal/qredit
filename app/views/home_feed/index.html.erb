<div class="max-w-6xl mx-auto space-y-6">

  <!-- Search -->
  <div class="flex flex-col sm:flex-row gap-3 items-center">
    <%= form_with url: root_path,
        method: :get,
        scope: :query,
        data: { turbo_frame: "questions" },
        class: "flex flex-1 gap-3 items-center" do |f| %>

      <!-- search by title/topic -->
      <div class="flex items-center gap-2 text-sm font-medium text-gray-700">
        <%= f.label :search_by, "Search by", class: "whitespace-nowrap" %>
      
        <div class="relative">
          <%= f.select :search_by, [["Title", "title"], ["Topic", "topic"]],
                {},
                class: "appearance-none border border-gray-300 rounded-lg px-3 py-2 pr-8 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400 cursor-pointer bg-white" %>
      
          <!-- custom arrow -->
          <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center text-gray-400">
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- text field to search -->
      <div class="relative flex-1">
        <%= f.text_field :content,
              placeholder: "Search questions...",
              class: "w-full border border-gray-300 rounded-lg px-4 py-2 pr-10 text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 focus:border-gray-400" %>

        <!-- Clear -->
        <%= link_to root_path,
              class: "absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 text-lg font-medium" do %>
          &times;
        <% end %>
      </div>

    <% end %>
  </div>

  <!-- n new questions -->
  <% if user_signed_in? %>
    <%= turbo_stream_from "questions_feed" %>
    <div id="new_questions_banner"></div>
  <% end %>

  <!-- Results -->
  <turbo-frame id="questions">
    <div class="space-y-6">
      <% if @questions.any? %>
        <%= render partial: "questions/question", collection: @questions %>
      <% else %>
        <p class="text-gray-400 text-center py-10 text-sm">
          No results found
        </p>
      <% end %>
    </div>
  </turbo-frame>

</div>
