<div class="max-w-6xl mx-auto space-y-6">

  <!-- Search -->
  <%= form_with url: root_path,
        method: :get,
        scope: :query,
        data: { turbo_frame: "questions" },
        class: "flex flex-col sm:flex-row gap-3 items-center" do |f| %>

    <div class="flex items-center gap-2 text-sm font-medium text-gray-700">
      <%= f.label :search_by, "Search by", class: "whitespace-nowrap" %>
      <%= f.select :search_by, [:title, :topic],
            class: "border border-violet-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-violet-400 focus:border-violet-400" %>
    </div>

    <%= f.text_field :content,
          placeholder: "Search questions...",
          class: "flex-1 border border-violet-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-violet-400 focus:border-violet-400" %>
  <% end %>

  <!-- Results -->
  <turbo-frame id="questions">
    <div class="space-y-6">
      <% if @questions.any? %>
        <%= render partial: "questions/question", collection: @questions %>
      <% else %>
        <p class="text-grey-400 text-center py-10 text-sm">
          No results found
        </p>
      <% end %>
    </div>
  </turbo-frame>

</div>
