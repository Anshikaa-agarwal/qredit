<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Question Answer Platform" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Question Answer Platform">
    <meta name="mobile-web-app-capable" content="yes">
    <script src="https://kit.fontawesome.com/0f5c8d7587.js" crossorigin="anonymous"></script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<body class="bg-gray-50 text-gray-800 text-base">
  <!-- Top Navbar -->
  <nav class="fixed top-0 inset-x-0 h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 z-50">
    <div class="text-2xl font-bold text-violet-600">
      Qredit
    </div>

    <% if user_signed_in? %>
      <%= link_to user_path(current_user) do %>
        <%= image_tag current_user.displayed_avatar,
        class: "w-10 h-10 rounded-full border border-amber-200 object-cover hover:ring-2 hover:ring-amber-300 transition" %>
      <% end %>
    <% else %>
      <div class="flex items-center gap-4 text-base">
        <%= link_to "Login", new_user_session_path, class: "px-5 py-2.5 rounded-lg border border-violet-600 text-violet-600 hover:bg-violet-600 hover:text-white transition" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "px-5 py-2.5 rounded-lg bg-violet-600 text-white hover:bg-violet-700 transition" %>
      </div>
    <% end %>
  </nav>

  <div class="flex pt-16 min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 px-5 py-6 hidden md:block">
      <nav class="flex flex-col gap-3 text-base font-medium">
        <%= link_to "Home", "/", class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
    
        <% if user_signed_in? %>
          <%= link_to "My Questions", "/", class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
          <%= link_to "My Answers", "/", class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
          <%= link_to "Credits", "/", class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
          <%= link_to "Following", "/", class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
          <%= link_to "My Profile", user_path(current_user), class: "px-4 py-2.5 rounded-lg hover:bg-gray-100" %>
    
          <%= button_to "Log out",
                destroy_user_session_path,
                method: :delete,
                class: "mt-4 w-full text-left px-4 py-2.5 rounded-lg text-violet-600 hover:bg-violet-50 hover:text-violet-700 transition font-medium" %>
        <% end %>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 px-8 py-7 text-base">
      <% if notice %>
        <div class="mb-5 p-4 rounded-lg bg-green-100 text-green-800 border border-green-200 text-base">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="mb-5 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200 text-base">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>
</body>
</html>
