<h2 class="text-2xl font-semibold mb-6 text-center text-violet-600">Sign up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name),
      html: { class: "max-w-md mx-auto bg-white p-6 rounded border border-violet-200" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-4">
    <%= f.label :name, class: "block text-sm mb-1 text-gray-800" %>
    <%= f.text_field :name, autofocus: true, autocomplete: "name",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-4">
    <%= f.label :email, class: "block text-sm mb-1 text-gray-800" %>
    <%= f.email_field :email, autocomplete: "email",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "block text-sm mb-1 text-gray-800" %>
    <% if @minimum_password_length %>
      <p class="text-xs text-gray-500 mb-1">(<%= @minimum_password_length %> characters minimum)</p>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-6">
    <%= f.label :password_confirmation, class: "block text-sm mb-1 text-gray-800" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= f.submit "Sign up",
          class: "w-full bg-violet-600 text-white py-2 rounded hover:bg-violet-700 transition" %>
  </div>
<% end %>

<div class="text-center mt-4 text-sm text-blue-600">
  <%= render "devise/shared/links" %>
</div>
