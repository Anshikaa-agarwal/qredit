<div class="max-w-md mx-auto bg-white p-6 rounded border border-violet-200 mt-12 text-gray-700">
  <p class="mb-4 font-medium">Hello <%= @resource.email %>!</p>

  <p class="mb-4">
    Someone has requested a link to change your password. You can do this through the link below:
  </p>

  <p class="mb-4">
    <%= link_to 'Change my password', edit_password_url(@resource, reset_password_token: @token),
          class: "inline-block bg-violet-600 text-white py-2 px-4 rounded hover:bg-violet-700 transition" %>
  </p>

  <p class="mb-2">If you didn't request this, please ignore this email.</p>
  <p>Your password won't change until you access the link above and create a new one.</p>
</div>
