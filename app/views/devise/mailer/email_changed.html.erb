<div class="max-w-md mx-auto bg-white p-6 rounded border border-violet-200 mt-12 text-gray-700">
  <p class="mb-4 font-medium">Hello <%= @email %>!</p>

  <% if @resource.try(:unconfirmed_email?) %>
    <p>Your email is being changed to <%= @resource.unconfirmed_email %>.</p>
  <% else %>
    <p>Your email has been changed to <%= @resource.email %>.</p>
  <% end %>
</div>
