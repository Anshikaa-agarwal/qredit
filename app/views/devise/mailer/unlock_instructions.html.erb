<div class="max-w-md mx-auto bg-white p-6 rounded border border-violet-200 mt-12 text-gray-700">
  <p class="mb-4 font-medium">Hello <%= @resource.email %>!</p>

  <p class="mb-4">
    Your account has been locked due to too many unsuccessful sign-in attempts.
  </p>

  <p class="mb-4">Click the link below to unlock your account:</p>

  <p class="mb-4">
    <%= link_to 'Unlock my account', unlock_url(@resource, unlock_token: @token),
          class: "inline-block bg-violet-600 text-white py-2 px-4 rounded hover:bg-violet-700 transition" %>
  </p>
</div>
