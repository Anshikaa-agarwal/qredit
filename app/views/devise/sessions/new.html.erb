<h2 class="text-2xl font-semibold mb-6 text-center text-violet-600">Log in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name),
      html: { class: "max-w-md mx-auto bg-white p-6 rounded border border-violet-200" }) do |f| %>

  <div class="mb-4">
    <%= f.label :email, class: "block text-sm mb-1 text-gray-800" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "block text-sm mb-1 text-gray-800" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="mb-4 flex items-center gap-2 text-sm">
      <%= f.check_box :remember_me, class: "h-4 w-4" %>
      <%= f.label :remember_me, class: "text-gray-800" %>
    </div>
  <% end %>

  <div>
    <%= f.submit "Log in",
          class: "w-full bg-violet-600 text-white py-2 rounded hover:bg-violet-700 transition" %>
  </div>

<% end %>

<div class="text-center mt-4 text-sm text-blue-600">
  <%= render "devise/shared/links" %>
</div>
