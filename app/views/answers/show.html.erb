<div class="max-w-3xl mx-auto mt-10 px-2">

  <h1 class="text-2xl font-semibold text-gray-800 mb-6">
    Answer
  </h1>

  <%= render "shared/user_details", user: @answer.user %>

  <div class="mt-4">
    <p class="text-sm text-gray-500 mb-1">Question</p>

    <%= link_to @answer.question,
        class: "text-lg font-medium text-violet-700 hover:text-violet-900 hover:underline" do %>
      <%= @answer.question.title %>
    <% end %>
  </div>

  <div class="mt-6 p-6 border border-gray-300 rounded-lg bg-white">
    <p class="text-gray-700 whitespace-pre-line">
      <%= @answer.content %>
    </p>
  </div>

</div>