<div class="max-w-6xl mx-auto mt-4 px-1">
  <%= link_to "← Back",
        request.referer || root_path,
        class: "text-sm font-medium text-violet-800 hover:text-violet-950" %>
</div>

<div class="max-w-3xl mx-auto mt-10 bg-white p-6 rounded border border-violet-200">

  <!-- Profile Header -->
  <div class="flex flex-col items-center mb-8">
    <%= image_tag(@user.displayed_avatar,
                  class: "w-32 h-32 rounded-full border border-violet-200 mb-3 object-cover") %>
    <h1 class="text-3xl font-semibold text-violet-600 mb-3"><%= @user.name %></h1>

    <% if @user == current_user %>
      <%= form_with model: current_user,
            url: update_profile_user_path(current_user),
            method: :patch,
            class: "w-full max-w-xs" do |f| %>
        <%= f.file_field :avatar, class: "w-full border border-violet-200 rounded px-3 py-2 mb-3 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
        <%= f.submit "Update Avatar", class: "w-full bg-violet-600 text-white py-2 rounded hover:bg-violet-700 transition font-medium text-lg" %>
      <% end %>

      <% if @user.avatar.attached? %>
        <%= button_to "Remove avatar",
            update_profile_user_path(current_user),
            method: :patch,
            params: { remove_avatar: true },
            class: "mt-2 text-sm text-red-600 hover:text-red-800 underline underline-offset-2 font-medium" %>
      <% end %>
    <% end %>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 gap-6 mb-8 text-center">
    <%= link_to user_followers_list_path(@user), class: "block group" do %>
      <div class="p-3 bg-violet-50 rounded border border-violet-200
                  transition duration-200 ease-in-out
                  hover:bg-violet-100 hover:border-violet-300
                  hover:shadow-sm hover:-translate-y-0.5">

        <p class="text-base text-gray-600
                  group-hover:text-gray-800 transition">
          Followers
        </p>

        <p class="text-2xl font-semibold text-violet-600
                  group-hover:text-violet-700 transition">
          <%= @user.followers.size %>
        </p>

      </div>
    <% end %>

    <%= link_to user_followers_list_path(@user), class: "block group" do %>
      <div class="p-3 bg-violet-50 rounded border border-violet-200
                transition duration-200 ease-in-out
                hover:bg-violet-100 hover:border-violet-300
                hover:shadow-sm hover:-translate-y-0.5">
  
        <p class="text-base text-gray-600
                  group-hover:text-gray-800 transition">
          Following
        </p>
    
        <p class="text-2xl font-semibold text-violet-600
                  group-hover:text-violet-700 transition">
          <%= @user.followees.size %>
        </p>
      </div>
    <% end %>

    <div class="p-3 bg-violet-50 rounded border border-violet-200">
      <p class="text-base text-gray-600">Credits</p>
      <p class="text-2xl font-semibold text-violet-600"><%= @user.credits %></p>
    </div>
    <%= link_to questions_path(user_id: @user), class: "block group" do %>
      <div class="p-3 bg-violet-50 rounded border border-violet-200
                  transition duration-200 ease-in-out
                  hover:bg-violet-100 hover:border-violet-300
                  hover:shadow-sm hover:-translate-y-0.5">

        <p class="text-base text-gray-600 group-hover:text-gray-800 transition">
          Questions
        </p>

        <p class="text-2xl font-semibold text-violet-600
                  group-hover:text-violet-700 transition">
          <%= @user.questions.size %>
        </p>

      </div>
    <% end %>
  </div>

  <!-- Topics -->
  <div class="mb-6">
    <p class="text-lg font-medium text-gray-700 mb-2">Interested Topics</p>
    <div class="flex flex-wrap gap-2">
      <% @user.topics.each do |topic| %>
        <span class="bg-orange-100 text-orange-600 px-3 py-1 rounded-full text-md font-semibold border border-orange-200">
          <%= topic.name %>
          <% if @user == current_user %>
            <% assignement = current_user.topic_assignements.find_by(topic_id: topic.id)%>
            <%= button_to "x",
                user_topic_assignement_path(current_user, assignement.id),
                method: :delete,
                form_class: "inline-block m-0 p-0",
                class: "ml-2 text-red-800" %>
          <% end %>
        </span>
      <% end %>
    </div>
  </div>

  <!-- Add Topics -->
  <% if @user == current_user %>
    <div>
      <p class="text-lg font-medium text-gray-700 mb-2">Add more topics</p>
      <%= form_with model: TopicAssignement.new,
            url: user_topic_assignements_path(current_user),
            method: :post,
            class: "flex gap-3 items-center" do |f| %>
        <%= select_tag :add_topic_id,
              options_from_collection_for_select(@remaining_topics, :id, :name),
              prompt: "Select a topic",
              class: "border border-violet-200 rounded px-3 py-2 w-full text-base focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
        <%= f.submit "Add", class: "bg-violet-600 text-white px-4 py-2 rounded hover:bg-violet-700 transition font-medium text-base" %>
      <% end %>
    </div>
  <% end %>

</div>
