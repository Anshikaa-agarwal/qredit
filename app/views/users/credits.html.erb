<div class="p-8">

  <!-- Page Header -->
  <div class="max-w-6xl mx-auto">

    <!-- Summary Card -->
    <div class="bg-white shadow rounded-2xl p-6 mb-8 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-600">
          Total Credits
        </h2>
        <p class="text-4xl font-bold text-indigo-600 mt-2">
          <%= @credit_count %>
        </p>
      </div>

      <div>
        <%= link_to "Purchase Credits",
      new_credit_purchase_path,
      class: "inline-flex items-center
              px-4 py-2
              rounded-xl
              border border-violet-200
              bg-violet-100
              text-violet-800
              text-sm font-medium
              hover:bg-violet-100
              transition" %>
      </div>
    </div>

    <!-- Transactions Section -->
    <div class="bg-white shadow rounded-2xl p-6">
      <h3 class="text-xl font-semibold text-gray-800 mb-6">
    Transaction History
      </h3>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">

          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Date
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Units
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Type
              </th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                Reason
              </th>
            </tr>
          </thead>

          <tbody class="bg-white divide-y divide-gray-200">
            <% @transactions.each do |t| %>
              <tr class="hover:bg-gray-50 transition">

                <!-- Date -->
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  <%= t.created_at.strftime("%d %b %Y, %I:%M %p") %>
                </td>

                <!-- Units -->
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold
                  <%= t.type == 'earnt' ? 'text-green-600' : 'text-red-600' %>">
                  <%= t.type == 'earnt' ? '+' : '-' %><%= t.units %>
                </td>

                <!-- Type Badge -->
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <span class="px-2 py-1 rounded-full text-xs font-semibold
                    <%= t.type == 'earnt' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <%= t.type.capitalize %>
                  </span>
                </td>

                <!-- Reason  -->
                <td class="px-6 py-4 text-sm">
                  <% if set_parent_chain(t.source).present? %>
                    <%= link_to t.reason || "View details",
                          set_parent_chain(t.source),
                          class: "text-indigo-600 hover:underline font-medium" %>
                  <% elsif t.source.present? %>
                    <%= link_to t.reason || "View details",
                          (t.source),
                          class: "text-indigo-600 hover:underline font-medium" %>
                  <% else %>
                    <span class="text-gray-700">
                      <%= t.reason.presence || "Manual transaction" %>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  </div>

</div>
