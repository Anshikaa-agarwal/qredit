<% if @question.errors.any? %>
  <ul class="mb-5 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200">
    <% @question.errors.full_messages.each do |e| %>
      <li><%= e %></li>
    <% end %>
  </ul>
<% end %>

<div class="max-w-6xl mx-auto mt-4 px-1">
  <%= link_to "← Back",
        request.referer || root_path,
        class: "text-sm font-medium text-violet-800 hover:text-violet-950" %>
</div>

<%= turbo_frame_tag "question_show" do %>

  <%= render @question %>

  <% if @question.published? %>

    <% if @active_tab == :answers %>

      <% if user_signed_in? %>
        <%= render partial: 'write_answer_btn', locals: { question: @question } %>
      <% end %>

      <p class="max-w-6xl mx-auto mt-6 mb-3 px-1 text-xl font-semibold text-gray-600">
        Answers
      </p>

      <div class="max-w-6xl mx-auto mt-8 space-y-6">
        <%= render partial: 'answers/answer',
                   collection: @question.answers,
                   as: :answer %>
      </div>

    <% else %>

      <% if user_signed_in? %>
        <%= render partial: 'comments/post_comment_btn',
                   locals: { commentable: @question } %>
      <% end %>

      <p class="max-w-6xl mx-auto mt-6 mb-3 px-1 text-xl font-semibold text-gray-600">
        Comments
      </p>

      <div class="max-w-6xl mx-auto mt-8">
        <%= render partial: 'comments/comment',
                   collection: @question.comments,
                   as: :comment %>
      </div>

  <% end %>
<% end %>
<% end %>