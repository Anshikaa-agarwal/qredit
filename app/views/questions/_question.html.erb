<div class="max-w-6xl mx-auto my-6 relative">

  <!-- Edit/Delete/Draft -->
  <% if current_user == question.user %>
    <div class="absolute top-4 right-4 flex gap-3 text-gray-500 z-10">

      <% if question.draft? %>
        <span class="px-3 py-1 text-xs font-semibold rounded-full bg-amber-100 text-amber-700 border border-amber-200">
          Draft
        </span>
      <% end %>

      <% if question.edited_at %>
        <span class="px-3 py-1 text-[11px] font-semibold rounded-full bg-violet-50 text-violet-700 border border-violet-200 tracking-wide">
          Edited
        </span>
      <% end %>

      <% if question.editable? %>
        <%= link_to edit_question_path(question),
              class: "hover:text-violet-600",
              data: { turbo_frame: "_top" } do %>
          <i class="fa-regular fa-pen-to-square"></i>
        <% end %>
      <% else %>
        <span
          class="text-gray-300 cursor-not-allowed relative group">
          <i class="fa-regular fa-pen-to-square"></i>

          <!-- tooltip -->
          <span class="absolute right-0 top-6 hidden group-hover:block
                       bg-gray-800 text-white text-xs rounded px-2 py-1 whitespace-nowrap">
            Cannot edit: answers/comments/votes exist
          </span>
        </span>
      <% end %>

      <%= button_to question_path(question),
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "hover:text-red-500 bg-transparent border-none p-0" do %>
        <i class="fa-regular fa-trash-can"></i>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white border border-violet-100 rounded-xl p-7 space-y-6 shadow-sm">

    <%= link_to question_path(question), class: "block no-underline space-y-6", data: { turbo_frame: "_top" } do %>

      <div class="flex flex-col gap-0">
        <%= render partial: "shared/user_details", locals: { user: question.user } %>

        <% if question.published? %>
        <p class="text-xs text-gray-400 mt-1">
          Posted
          <%= question.posted_at >= 1.day.ago ?
                time_ago_in_words(question.posted_at) + " ago" :
                question.posted_at.to_date %>
        </p>
        <% end %>
      </div>

      <%= render partial: 'shared/display_topics', locals: { topicable: question } %>

      <div>
        <p class="text-xl font-semibold text-gray-800 mb-1"><%= question.title %></p>
        <p class="text-gray-600 leading-relaxed"><%= markdown(question.content) %></p>

        <% if question.pdf.attached? %>
          <div class="mt-3">
            <%= link_to question.pdf.filename,
                  url_for(question.pdf),
                  class: "text-blue-600 text-sm font-medium hover:underline",
                  data: { turbo_frame: "_top" } %>
          </div>
        <% end %>
      </div>

    <% end %>

    <!-- Publish CTA -->
    <% if question.draft? %>
      <div class="pt-3 border-t border-neutral-100 flex justify-end">
        <%= button_to publish_question_path(question),
              method: :patch,
              data: { turbo_confirm: "Publish this question?" },
              class: "text-sm text-violet-600 hover:text-violet-700 font-medium bg-transparent border-none p-0" do %>
          Publish
        <% end %>
      </div>
    <% end %>

  </div>
</div>
