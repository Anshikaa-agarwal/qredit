<div class="max-w-6xl mx-auto my-6 relative">

  <!-- Edit/Delete -->
  <% if current_user == question.user %>
    <div class="absolute top-4 right-4 flex gap-3 text-gray-500 z-10">
      <%= link_to edit_question_path(question), class: "hover:text-violet-600" do %>
        <i class="fa-regular fa-pen-to-square"></i>
      <% end %>

      <%= button_to question_path(question),
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "hover:text-red-500 bg-transparent border-none p-0" do %>
        <i class="fa-regular fa-trash-can"></i>
      <% end %>
    </div>
  <% end %>

  <%= link_to question_path(question), class: "block no-underline" do %>
    <div class="bg-white border border-violet-100 rounded-xl p-7 space-y-6 shadow-sm">

      <!-- User -->
      <div class="flex items-center gap-4">
        <%= image_tag(question.user.avatar,
              class: "w-12 h-12 rounded-full border border-gray-300 object-cover") %>

        <div>
          <p class="text-lg font-semibold text-gray-800"><%= question.user.name %></p>
          <p class="text-sm text-gray-600"><%= question.user.followers.count %> followers</p>
          <p class="text-xs text-gray-400">
            Posted <%= question.created_at >= 1.day.ago ? time_ago_in_words(question.created_at) + " ago" : question.posted_at_date %>
          </p>
        </div>
      </div>

      <!-- Topics -->
      <% if question.topics.any? %>
        <div class="flex flex-wrap gap-2">
          <% question.topics.each do |t| %>
            <span class="bg-orange-50 text-orange-600 border border-orange-100 px-3 py-1 rounded-full text-sm font-medium">
              <%= t.name %>
            </span>
          <% end %>
        </div>
      <% end %>

      <!-- Question -->
      <div>
        <p class="text-xl font-semibold text-gray-800 mb-1"><%= question.title %></p>
        <p class="text-gray-700 leading-relaxed"><%= markdown(question.content) %></p>

        <% if question.pdf.attached? %>
          <div class="mt-3">
            <%= link_to question.pdf.filename,
                  url_for(question.pdf),
                  class: "text-blue-600 text-sm font-medium hover:underline" %>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>

</div>
