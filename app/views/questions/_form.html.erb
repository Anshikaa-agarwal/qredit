<%= form_with model: @question,
              class: "max-w-2xl mx-auto bg-white p-6 rounded border border-violet-200 space-y-5" do |f| %>

  <% if @question.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-600 p-3 rounded text-sm">
      <p class="font-medium mb-1">
        <%= pluralize(@question.errors.count, "error") %> prevented this question from being saved:
      </p>
      <ul class="list-disc ml-5">
        <% @question.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title -->
  <div>
    <%= f.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <!-- Content -->
  <div>
    <%= f.label :content, "Content", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :content, rows: 5,
          class: "w-full px-3 py-2 border border-violet-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <!-- Topics -->
  <div>
    <%= f.label :topic_ids, "Topics", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :topic_ids,
          @topics,
          :id,
          :name,
          { prompt: "Select topics" },
          { multiple: true,
            class: "w-full border border-violet-200 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500" } %>
  </div>

  <!-- PDF -->
  <div>
    <%= f.label :pdf, "PDF (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>  

    <div class="flex items-center gap-3 border border-violet-200 rounded px-3 py-2 bg-violet-50">
      <%= f.file_field :pdf,
            accept: ".pdf",
            class: "text-sm text-gray-700 file:border-0 file:bg-transparent file:text-violet-600 file:font-medium file:mr-3 focus:outline-none" %>
    </div>  

    <p class="text-xs text-gray-500 mt-1">Upload a PDF if you want to attach extra details.</p>
  </div>


  <!-- Buttons -->
  <div class="flex gap-3 pt-2">
    <% if @question.new_record? %>
      <%= f.submit "Save as Draft",
        name: "draft",
        class: "bg-violet-600 text-white px-5 py-2 rounded hover:bg-violet-700 transition-colors duration-200 font-medium shadow-sm" %>
    <% else %>
      <%= f.submit "Save Changes",
            class: "bg-violet-600 text-white px-5 py-2 rounded hover:bg-violet-700 transition font-medium" %>
    <% end %>
  </div>

<% end %>
