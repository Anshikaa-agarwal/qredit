<div class="min-h-screen bg-gray-100 p-8">

  <h1 class="text-2xl font-semibold text-gray-800 mb-8">
    Admin Dashboard
  </h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- Users -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-700">
          Users
        </h2>
        <%= link_to "View all", admin_users_path,
              class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
      </div>

      <p class="text-sm text-gray-500 mb-4">
        Users created over time
      </p>

      <%= line_chart @user_by_date %>
    </div>


    <!-- Questions by Topic -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-medium text-gray-700 mb-4">
        Questions by Topic
      </h2>

      <%= link_to "View all topics", admin_topics_path,
              class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
      </div>

      <%= pie_chart @questions_by_topic %>
    </div>


    <!-- Questions by Weekday -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-medium text-gray-700 mb-4">
        Questions by Weekday
      </h2>

      <%= link_to "All questions", admin_questions_path,
              class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
      </div>

      <%= column_chart @questions_by_week_day %>
    </div>


    <!-- Credit Purchase Stats -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-medium text-gray-700 mb-4">
        Credit Purchase Stats
      </h2>

      <%= bar_chart @popular_plans %>
    </div>

  </div>

</div>