<div class="max-w-2xl mx-auto px-6 py-8">
  
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-medium text-gray-800">
      Topics
    </h1>

    <%= link_to "Add topic",
        new_admin_topic_path,
        data: { turbo_frame: "new_topic_frame" },
        class: "inline-flex items-center px-3 py-1 text-sm
                border border-violet-600 text-violet-600
                rounded-full hover:bg-violet-50 transition" %>
  </div>

  <%= turbo_frame_tag id="new_topic_frame" %>

  <%= turbo_frame_tag id="admin_topics_list" do %>
    <div class="space-y-4">
      <%= render partial: "topic", collection: @topics %>
    </div>
  <% end %>

</div>