<div class="max-w-4xl mx-auto px-6 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-semibold text-gray-800">
      Topics
    </h1>

    <%= link_to "Add topic",
        new_admin_topic_path,
        data: { turbo_frame: "new_topic_frame" },
        class: "inline-flex items-center px-4 py-2 text-sm
                border border-violet-600 text-violet-600
                rounded-full hover:bg-violet-50 transition" %>
  </div>

  <%= turbo_frame_tag "new_topic_frame" %>

  <!-- Strategic Insights Section -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">

    <!-- Fastest Growing Topic -->
    <div class="p-5 bg-white border border-gray-200 rounded-2xl shadow-sm">
      <p class="text-xs text-gray-500 uppercase tracking-wide">
        Most engaging topic
      </p>

      <% if @most_engaging_topic.present? %>
        <p class="mt-3 text-lg font-semibold text-gray-800">
          <%= @most_engaging_topic.name %>
        </p>
        <p class="text-sm text-green-600 mt-1">
          <%= @most_engaging_topic.questions.size %> Questions,
          <%= @most_engaging_topic.users.size %> Users
        </p>
      <% else %>
        <p class="mt-3 text-sm text-gray-400">
          No growth data available
        </p>
      <% end %>
    </div>


  </div>

  <div>
    <h2 class="text-sm font-semibold text-gray-700 mb-4 uppercase tracking-wide">
      All Topics
    </h2>

    <%= turbo_frame_tag "admin_topics_list" do %>
      <div class="space-y-4">
        <%= render partial: "topic", collection: @topics %>
      </div>
    <% end %>
  </div>

</div>