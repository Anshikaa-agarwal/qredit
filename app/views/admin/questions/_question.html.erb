<%= turbo_frame_tag dom_id(question, :admin) do %>
  <div class="border border-gray-100 rounded-2xl px-7 py-6 mb-6 hover:border-violet-300 hover:bg-gray-50/40 transition">

    <div class="flex items-start justify-between">

      <!-- Left -->
      <div class="flex items-start gap-5">

        <span class="text-base text-gray-400 mt-1">
          <%= question_counter + 1 %>.
        </span>

        <div>
          <%= link_to question_path(question),
                data: { turbo_frame: "_top" },
                class: "text-lg font-semibold text-gray-800 hover:text-violet-600 transition" do %>
            <%= question.title %>
          <% end %>

          <!-- Created At -->
          <p class="text-xs text-gray-400 mt-1">
            Created <%= (question.created_at) %>
          </p>

          <!-- Status -->
          <div class="mt-3">
            <span class="text-xs font-medium px-3 py-1 rounded-full
              <%= case question.status
                  when "published" then "bg-green-100 text-green-700"
                  when "unpublished" then "bg-red-100 text-red-600"
                  else "bg-gray-100 text-gray-500"
                  end %>">
              <%= question.status.to_s.capitalize %>
            </span>
          </div>
        </div>

      </div>

      <!-- Stats -->
      <div class="flex items-center gap-10 text-sm text-gray-500">

        <div class="text-center">
          <p class="text-base font-semibold text-gray-800"><%= question.answers.size %></p>
          <p class="text-xs tracking-wide text-gray-400 uppercase">Answers</p>
        </div>

        <div class="text-center">
          <p class="text-base font-semibold text-gray-800"><%= question.comments.size %></p>
          <p class="text-xs tracking-wide text-gray-400 uppercase">Comments</p>
        </div>

        <div class="text-center">
          <p class="text-base font-semibold text-violet-600"><%= question.upvotes_count %></p>
          <p class="text-xs tracking-wide text-gray-400 uppercase">Upvotes</p>
        </div>

        <div class="text-center">
          <p class="text-base font-semibold text-gray-400"><%= question.downvotes_count %></p>
          <p class="text-xs tracking-wide text-gray-400 uppercase">Downvotes</p>
        </div>

      </div>

    </div>

  </div>
<% end %>