<%= form_with url: admin_questions_path,
        method: :get, 
        data: { turbo_frame: "admin_questions_list" },
  class: "bg-white p-6 rounded-2xl shadow-sm border border-violet-100 space-y-6" do |f| %>

  <!-- Topic Filter -->
  <div class="space-y-2">
    <%= f.label :topic_id, "Select Topic",
      class: "block text-sm font-medium text-gray-900" %>

    <%= f.select :topic_id,
          Topic.order(:name).map { |t| [t.name, t.id] },
          { include_blank: "All Topics" },
          class: "w-full border border-violet-200 rounded-lg px-3 py-2
                  focus:ring-2 focus:ring-violet-400 focus:border-violet-400
                  focus:outline-none transition"
    %>
  </div>

  <!-- Sort -->
  <div class="space-y-3">
    <p class="text-sm font-medium text-grey-900">Sort By</p>

    <div class="flex items-center gap-8">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :sort, :desc,
              class: "text-grey-600 focus:ring-violet-500" %>
        <span class="text-grey-800 text-sm">New</span>
      </label>

      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :sort, :asc,
              class: "text-grey-600 focus:ring-violet-500" %>
        <span class="text-grey-800 text-sm">Old</span>
      </label>
    </div>
  </div>

  <!-- Date Range -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-2">
      <%= f.label :from, "From Date",
        class: "block text-sm font-medium text-grey-900" %>

      <%= f.date_field :from,
            class: "w-full border border-violet-200 rounded-lg px-3 py-2
                    focus:ring-2 focus:ring-violet-400 focus:border-violet-400
                    focus:outline-none transition"
      %>
    </div>

    <div class="space-y-2">
      <%= f.label :to, "To Date",
        class: "block text-sm font-medium text-grey-900" %>

      <%= f.date_field :to,
            class: "w-full border border-violet-200 rounded-lg px-3 py-2
                    focus:ring-2 focus:ring-violet-400 focus:border-violet-400
                    focus:outline-none transition"
      %>
    </div>
  </div>

  <!-- Submit Button -->
  <div>
    <%= f.submit "Apply Filters",
          class: "w-full md:w-auto bg-violet-500 text-white
                  px-6 py-2.5 rounded-lg
                  hover:bg-violet-700
                  active:scale-95
                  transition-all duration-200
                  font-medium shadow-sm"
    %>
  </div>

<% end %>