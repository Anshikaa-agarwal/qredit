<div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 hover:shadow-md transition duration-200">
  
  <div class="space-y-1">
    <%= link_to user_path(user), class: "text-lg font-semibold text-slate-800 hover:text-slate-600 transition" do %>
      <%= user.name %>
    <% end %>

    <p class="text-sm text-slate-500"><%= user.email %></p>
  </div>

  <div class="my-5 h-px bg-slate-100"></div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-y-5 gap-x-6">
    <% { Questions: user.questions.size, Answers: user.answers.size, Comments: user.comments.size, Votes: user.votes.size }.each do |label, value| %>
      <div class="space-y-1">
        <p class="text-xs uppercase tracking-wide text-slate-400"><%= label %></p>
        <p class="text-base font-semibold text-slate-800"><%= value %></p>
      </div>
    <% end %>
  </div>
</div>