<!-- app/views/credit_purchases/show.html.erb -->
<div class="max-w-xl mx-auto my-10 bg-white shadow-lg rounded-lg p-6 border border-gray-200">
  <h1 class="text-2xl font-bold mb-4 text-center">Credit Purchase Receipt</h1>

  <div class="mb-4">
    <p class="text-gray-600"><span class="font-semibold">Transaction ID:</span> <%= @credit_purchase.stripe_transaction_id %></p>
    <p class="text-gray-600"><span class="font-semibold">Date:</span> <%= @credit_purchase.created_at.strftime("%B %d, %Y %H:%M") %></p>
    <p class="text-gray-600"><span class="font-semibold">User ID:</span> <%= @credit_purchase.user_id %></p>
  </div>

  <div class="mb-4 border-t border-b border-gray-200 py-4">
    <p class="text-gray-700"><span class="font-semibold">Credits Purchased:</span> <%= @credit_purchase.unit %> units</p>
    <p class="text-gray-700"><span class="font-semibold">Amount Paid:</span> $<%= @credit_purchase.amount / 100.0 %></p>
    <p class="text-gray-700"><span class="font-semibold">Status:</span> 
      <% if @credit_purchase.status.to_i == 0 %>
        <span class="text-yellow-500 font-semibold">Pending</span>
      <% elsif @credit_purchase.status.to_i == 1 %>
        <span class="text-green-600 font-semibold">Paid</span>
      <% else %>
        <span class="text-red-600 font-semibold">Failed</span>
      <% end %>
    </p>
  </div>

  <div class="mt-6 text-center">
    <p class="text-gray-500">Thank you for your purchase!</p>
  </div>
</div>
