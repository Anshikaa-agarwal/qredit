<% following_relationship = current_user.following_relationships.where(followee: user).first %>

<% if following_relationship %>
  <%= button_to "Unfollow",
        user_follower_path(user, following_relationship),
        method: :delete,
        class: "text-gray-500 hover:text-gray-700 underline bg-transparent border-none p-0 text-sm font-medium cursor-pointer" %>
<% else %>
  <%= button_to "Follow",
        user_followers_path(user),
        method: :post,
        class: "text-violet-700 hover:text-violet-800 underline bg-transparent border-none p-0 text-sm font-medium cursor-pointer" %>
<% end %>
