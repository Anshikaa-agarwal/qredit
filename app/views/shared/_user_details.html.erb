<div class="flex items-center gap-4">

  <%= image_tag(user.displayed_avatar,
      class: "w-12 h-12 rounded-full border border-gray-200 object-cover") %>

  <div class="flex flex-col">
    
    <div class="flex items-center gap-2 text-sm">

      <p class="font-semibold text-gray-900">
        <%= user.name %>
      </p>

      <span class="text-gray-400">·</span>

      <% @relation = current_user.following_relationships.where(followee: user).first %>

      <% if @relation %>
        <%= button_to "Unfollow",
              user_follower_path(user, @relation),
              method: :delete,
              class: "text-gray-500 hover:text-gray-700
                      underline
                      bg-transparent border-none p-0
                      text-sm font-medium cursor-pointer" %>
      <% else %>
        <%= button_to "Follow",
              user_followers_path(user),
              method: :post,
              class: "text-violet-700 hover:text-violet-800
                      underline
                      bg-transparent border-none p-0
                      text-sm font-medium cursor-pointer" %>
      <% end %>

    </div>

    <p class="text-sm text-gray-500">
      <%= user.followers.count %> followers
    </p>

  </div>
</div>
