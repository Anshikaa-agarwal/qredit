<div
  id="notification_<%= notification.id %>"
  class="bg-white border border-gray-200 shadow-lg rounded-xl p-4 flex items-start justify-between gap-3 animate-in slide-in-from-right"
>

  <div class="flex-1">
    <% if notification.notifiable.present? %>
      <%= link_to notification.notifiable, class: "text-sm text-gray-800 hover:text-indigo-600 font-medium" do %>
        <%= notification.message %>
      <% end %>
    <% else %>
      <p class="text-sm text-gray-800 font-medium">
        <%= notification.message %>
      </p>
    <% end %>

    <p class="text-xs text-gray-400 mt-1">
      <%= time_ago_in_words(notification.created_at) %> ago
    </p>
  </div>

  <button
    type="button"
    class="text-gray-400 hover:text-gray-600"
    onclick="this.closest('#notification_<%= notification.id %>').remove()"
  >
    <i class="fa-solid fa-xmark"></i>
  </button>

</div>